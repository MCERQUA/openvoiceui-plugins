      "icon": "crm"
    },
    {
      "file": "pages/crm-setup.html",
      "name": "CRM Setup",
      "icon": "settings"
    }
  ],

  "routes": [
    {
      "module": "routes/crm.py",
      "blueprint": "twenty_crm_bp",
      "prefix": "/api/crm"
    }
  ],

  "requires_env": ["TWENTY_CRM_API_KEY"]
}
